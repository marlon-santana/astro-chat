# Example environment variables for astro-chat
# Copy this file to .env and fill the secrets before running
COHERE_API_KEY=
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.7
QDRANT_URL=http://localhost:6333# Local development environment variables
# For Cohere Embeddings (optional)
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-english-v2.0
COHERE_EMBED_URL=https://api.cohere.ai/v1/embed

# Ollama/local embedding (optional fallback)
OLLAMA_EMBEDDING_URL=http://localhost:11434/api/embed
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# Embedding behavior
EMBED_BATCH_SIZE=32
EMBED_DIM=384

# Chunking
CHUNK_WORDS=250
CHUNK_OVERLAP=25

# OCR
OCR_PDF=true
OCR_ENGINE=pdfjs
OCR_LANG=por